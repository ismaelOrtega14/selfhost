# =====================================================================
# selfhost — unified stack.env
# Gestionar desde Portainer. Rellenar todos los valores marcados.
# =====================================================================

# --- general ---
TZ=Europe/Madrid
PUID=1026
PGID=100

# --- network: Technitium DNS ---
DNS_SERVER_DOMAIN=dns-server
DNS_SERVER_FORWARDERS=1.1.1.1, 1.1.2.2

# --- security: Pangolin ---

# --- security: Traefik ---
TRAEFIK_LOG_LEVEL=DEBUG
LEGO_EXPERIMENTAL_CNAME_SUPPORT=true
LEGO_DISABLE_CNAME_SUPPORT=false

# --- security: Authentik ---
AUTHENTIK_POSTGRESQL__HOST=192.168.0.251
AUTHENTIK_POSTGRESQL__PORT=5433
AUTHENTIK_POSTGRESQL__NAME=authentik
AUTHENTIK_POSTGRESQL__USER=authentik
AUTHENTIK_REDIS__HOST=authentik-redis

# --- notflix: Transmission ---
USER=ismael

# --- notflix: Jackett ---
AUTO_UPDATE=true

# --- notflix: Seerr ---

# --- tracker: Yamtrack ---
REDIS_URL=redis://redis-yamtrack:6379
DB_HOST=192.168.0.251
DB_NAME=yamtrack
DB_USER=yamtrack
DB_PORT=5433

# --- bookmarks: Linkwarden ---
NEXTAUTH_URL=http://localhost:3000

# --- bookmarks: Meilisearch ---

# --- drive: Immich ---
IMMICH_MACHINE_LEARNING_MEMORY_LIMIT=4G

# --- maintenance: Shepherd ---
SLEEP_TIME=3600
IMAGE_AUTOCLEAN_LIMIT=5
IGNORELIST_SERVICES=label=shepherd.autodeploy=false

# --- mealie ---
ALLOW_SIGNUP=false
BASE_URL=https://mealie.ios-tools.dedyn.io
DB_ENGINE=postgres
POSTGRES_USER=mealie
POSTGRES_SERVER=192.168.0.251
POSTGRES_PORT=5433
POSTGRES_DB=mealie
OIDC_AUTH_ENABLED=true
OIDC_PROVIDER_NAME=authentik
OIDC_CONFIGURATION_URL=https://authentik.ios-tools.dedyn.io/application/o/mealie/.well-known/openid-configuration
OIDC_SIGNUP_ENABLED=true
OIDC_USER_GROUP=mealie-user
OIDC_ADMIN_GROUP=mealie-admin
OIDC_AUTO_REDIRECT=true
OIDC_REMEMBER_ME=true

# --- paperless ---
PAPERLESS_REDIS=redis://paperless-broker:6379
PAPERLESS_DBHOST=192.168.0.251
PAPERLESS_DBPORT=5433
PAPERLESS_TIME_ZONE=Europe/Madrid
PAPERLESS_OCR_LANGUAGE=spa
PAPERLESS_OCR_LANGUAGES=eng
PAPERLESS_APPS=allauth.socialaccount.providers.openid_connect
PAPERLESS_LOGOUT_REDIRECT_URL=https://authentik.ios-tools.dedyn.io/application/o/paperless/end-session/
PAPERLESS_AUTO_CREATE=true
PAPERLESS_AUTO_LOGIN=true
PAPERLESS_ENABLE_ALLAUTH=true
PAPERLESS_SOCIAL_ACCOUNT_SYNC_GROUPS=true
PAPERLESS_PRE_CONSUME_SCRIPT=/usr/src/paperless/scripts/removepassword.py
PAPERLESS_URL=https://paperless.ios-tools.dedyn.io
